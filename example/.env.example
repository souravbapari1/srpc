# Point the CLI at this example server when using contracts:* scripts.
SRPC_URL=http://localhost:3100
SRPC_CONTRACT_DIR=./contract

# Optional — protect /docs, /playground, and /api/contracts
# SRPC_API_KEY=your-secret
# SRPC_TOKEN=your-secret

# Optional — HTTP Basic auth for browser access to /docs and /playground
# SRPC_DOCS_USER=admin
# SRPC_DOCS_PASSWORD=secret

# CLI credentials (same values as above when auth is enabled)
# SRPC_USER=admin
# SRPC_PASSWORD=secret
